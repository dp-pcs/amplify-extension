{
  "manifest_version": 3,
  "name": "Amplifier — Substack Cookie Sync",
  "version": "1.0.1",
  "description": "One-click sync your Substack session to Amplifier",
  "permissions": ["cookies", "activeTab", "storage", "scripting", "tabs", "declarativeNetRequest"],
  "host_permissions": [
    "https://*.substack.com/*",
    "https://amplify.elelem.expert/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "declarative_net_request": {
    "rule_resources": []
  },
  "content_scripts": [
    {
      "matches": [
        "https://amplify.elelem.expert/*",
        "http://localhost:3000/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
